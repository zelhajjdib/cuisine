# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtenir ces valeurs sur : https://supabase.com → Projet → Settings → API
VITE_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...votre_cle_anon_publique

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Clé publique (frontend) : https://dashboard.stripe.com → Développeurs → Clés API
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...votre_cle_publique

# ─── Variables SERVEUR uniquement (Edge Functions Supabase) ──────────────────
# Ces variables ne vont PAS dans ce fichier .env — elles se configurent dans :
# Supabase Dashboard → Edge Functions → Secrets
#
# STRIPE_SECRET_KEY=sk_test_...votre_cle_secrete
# STRIPE_WEBHOOK_SECRET=whsec_...votre_webhook_secret
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...cle_service_role (depuis Settings > API)
